# Environment configuration for ZWARMIS Backend

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Session Configuration
SESSION_SECRET=zwarmis-secret-key-2026-change-this-in-production

# Email Configuration (Demo mode by default - set these for real email)
